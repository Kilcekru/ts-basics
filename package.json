{
	"name": "@kilcekru/ts-basics",
	"version": "5.0.0",
	"description": "Configuration for typescript and eslint",
	"keywords": [
		"typescript",
		"tsconfig",
		"eslint"
	],
	"license": "ISC",
	"author": {
		"name": "kilcekru",
		"email": "kilcekru@unkreativ.at"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Kilcekru/ts-basics"
	},
	"homepage": "https://github.com/Kilcekru/ts-basics/tree/main#readme",
	"bugs": "https://github.com/Kilcekru/ts-basics/issues",
	"engines": {
		"node": ">=22.14"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"default": "./index.js"
		},
		"./tsconfig-*.json": "./tsconfig-*.json"
	},
	"files": [
		"eslint/**/*",
		"index.js",
		"tsconfig-*.json"
	],
	"scripts": {
		"clean:all": "rm -rf node_modules",
		"lint": "eslint .",
		"prepack": "pnpm lint"
	},
	"dependencies": {
		"@eslint/js": "9.39.4",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-import": "2.32.0",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-simple-import-sort": "13.0.0",
		"eslint-plugin-solid": "0.14.5",
		"globals": "17.6.0",
		"typescript-eslint": "8.59.4"
	},
	"devDependencies": {
		"eslint": "^9.39.4",
		"typescript": "6.0.3"
	},
	"peerDependencies": {
		"eslint": "^9||^10",
		"typescript": "^6"
	}
}
